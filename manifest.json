{
  "id": "modly.ultrashape-refiner-process",
  "name": "UltraShape Refiner Process",
  "type": "process",
  "version": "0.1.0",
  "entry": "processor.js",
  "nodes": [
    {
      "id": "ultrashape-refiner",
      "name": "UltraShape Refiner Process",
      "type": "process",
      "input": "image",
      "output": "mesh",
      "inputs": [
        {
          "id": "reference_image",
          "name": "Reference Image",
          "type": "image",
          "required": true
        },
        {
          "id": "coarse_mesh",
          "name": "Coarse Mesh",
          "type": "mesh",
          "required": true
        }
      ],
      "outputs": [
        {
          "id": "refined_mesh",
          "name": "Refined Mesh",
          "type": "mesh",
          "required": true
        }
      ],
      "params_schema": {
        "type": "object",
        "properties": {
          "checkpoint": {
            "type": ["string", "null"],
            "default": null
          },
          "backend": {
            "type": "string",
            "enum": ["auto", "local", "remote", "hybrid"],
            "default": "auto"
          },
          "steps": {
            "type": "integer",
            "minimum": 1,
            "default": 30
          },
          "guidance_scale": {
            "type": "number",
            "exclusiveMinimum": 0,
            "default": 5.5
          },
          "seed": {
            "type": ["integer", "null"],
            "default": null
          },
          "preserve_scale": {
            "type": "boolean",
            "default": true
          },
          "output_format": {
            "type": "string",
            "enum": ["glb", "obj", "fbx", "ply"],
            "default": "glb"
          }
        }
      }
    }
  ],
  "testing_fallback_only": {
    "status": "temporary_non_native",
    "temporary": true,
    "non_native": true,
    "description": "Temporary structured request-bundle seam until Modly core supports native multi-input process ports.",
    "semantic_contract": "reference_image + coarse_mesh -> refined_mesh",
    "bundle_schema": {
      "reference_image": "path",
      "coarse_mesh": "path",
      "output_dir": "path",
      "checkpoint": "path|null",
      "params": "object"
    },
    "draft_manifest_seam": {
      "reason": "Current Modly manifest schema may not yet express the ideal multi-input process contract directly.",
      "forward_compatible_intent": "Preserve final semantic ids and ports now so native core support can adopt them without renaming the contract."
    }
  }
}
