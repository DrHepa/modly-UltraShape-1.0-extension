{
  "id": "modly.ultrashape-refiner-process",
  "name": "UltraShape Refiner Process",
  "type": "process",
  "version": "0.1.0",
  "entry": "processor.py",
  "nodes": [
    {
      "id": "ultrashape-refiner",
      "name": "UltraShape Refiner Process",
      "type": "process",
      "input": "image",
      "output": "mesh",
      "inputs": [
        {
          "name": "reference_image",
          "label": "Reference Image",
          "type": "image",
          "required": true
        },
        {
          "name": "coarse_mesh",
          "label": "Coarse Mesh",
          "type": "mesh",
          "required": true
        }
      ],
      "params_schema": [
        {
          "id": "backend",
          "label": "Backend",
          "type": "select",
          "default": "auto",
        "options": [
          { "value": "auto", "label": "auto" },
          { "value": "local", "label": "local" }
        ]
        },
        {
          "id": "steps",
          "label": "Steps",
          "type": "int",
          "default": 30
        },
        {
          "id": "guidance_scale",
          "label": "Guidance Scale",
          "type": "float",
          "default": 5.5
        },
        {
          "id": "seed",
          "label": "Seed",
          "type": "int",
          "default": -1
        },
        {
          "id": "output_format",
          "label": "Output Format",
        "type": "select",
        "default": "glb",
        "options": [{ "value": "glb", "label": "glb" }]
      }
      ]
    }
  ]
}
