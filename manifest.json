{
  "id": "modly.ultrashape-refiner-process",
  "name": "UltraShape Refiner Process",
  "version": "1.0.0",
  "shell": {
    "local_only": true,
    "processor": "processor.py",
    "setup": "setup.py"
  },
  "contract": {
    "kind": "process-refiner",
    "required_inputs": [
      "reference_image",
      "coarse_mesh"
    ],
    "output_artifact": "output_dir/refined.glb"
  },
  "forbidden_execution_modes": [
    "remote",
    "hybrid",
    "model-wrapper"
  ]
}
