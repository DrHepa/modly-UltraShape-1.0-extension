{
  "id": "modly.ultrashape-refiner-process",
  "name": "UltraShape Refiner Process",
  "type": "process",
  "version": "0.1.0",
  "entry": "processor.py",
  "nodes": [
    {
      "id": "ultrashape-refiner",
      "name": "UltraShape Refiner Process",
      "input": "image",
      "output": "mesh",
      "params_schema": [
        {
          "name": "checkpoint",
          "type": "file",
          "required": false
        },
        {
          "name": "coarse_mesh",
          "type": "file",
          "required": false
        },
        {
          "name": "backend",
          "type": "select",
          "default": "auto",
          "options": ["auto", "local", "remote", "hybrid"]
        },
        {
          "name": "steps",
          "type": "number",
          "default": 30
        },
        {
          "name": "guidance_scale",
          "type": "number",
          "default": 5.5
        },
        {
          "name": "seed",
          "type": "number",
          "required": false
        },
        {
          "name": "preserve_scale",
          "type": "boolean",
          "default": true
        },
        {
          "name": "output_format",
          "type": "select",
          "default": "glb",
          "options": ["glb", "obj", "fbx", "ply"]
        }
      ]
    }
  ],
  "testing_fallback_only": {
    "status": "temporary_non_native",
    "temporary": true,
    "non_native": true,
    "semantic_contract": "reference_image + coarse_mesh -> refined_mesh",
    "bundle_schema": {
      "reference_image": "path",
      "coarse_mesh": "path",
      "output_dir": "path",
      "checkpoint": "path|null",
      "params": "object"
    },
    "draft_manifest_seam": {
      "reason": "Current Modly manifest schema may not yet express the ideal multi-input process contract directly.",
      "forward_compatible_intent": "Preserve final semantic ids and ports now so native core support can adopt them without renaming the contract."
    }
  }
}
